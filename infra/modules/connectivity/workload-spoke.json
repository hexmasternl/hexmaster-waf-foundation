{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "3003311163235115811"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for the workload spoke network."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to the workload spoke resources."
      }
    },
    "spokeName": {
      "type": "string",
      "metadata": {
        "description": "Friendly workload name for the spoke."
      }
    },
    "spokeToken": {
      "type": "string",
      "metadata": {
        "description": "Normalized token used in resource names for the spoke."
      }
    },
    "vnetName": {
      "type": "string",
      "metadata": {
        "description": "Name of the workload spoke virtual network."
      }
    },
    "addressPrefixes": {
      "type": "array",
      "metadata": {
        "description": "Address prefixes assigned to the workload spoke VNet."
      }
    },
    "subnetPrefixes": {
      "type": "object",
      "metadata": {
        "description": "Subnet prefixes used inside the workload spoke."
      }
    },
    "hubAddressPrefixes": {
      "type": "array",
      "metadata": {
        "description": "Hub VNet address prefixes used to deny non-approved platform access."
      }
    },
    "hubSharedServicesPrefix": {
      "type": "string",
      "metadata": {
        "description": "Hub shared-services subnet prefix that workloads are allowed to reach through the hub peering."
      }
    },
    "hubPrivateEndpointsPrefix": {
      "type": "string",
      "metadata": {
        "description": "Hub private-endpoints subnet prefix that workloads are allowed to reach through the hub peering."
      }
    },
    "futureSpokeSupernet": {
      "type": "string",
      "metadata": {
        "description": "Future spoke supernet reserved by the landing zone for all workload spokes."
      }
    },
    "vpnClientAddressPool": {
      "type": "string",
      "metadata": {
        "description": "Point-to-Site VPN client pool used for break-glass operator reachability."
      }
    }
  },
  "variables": {
    "workloadSubnetName": "[take(format('snet-{0}-workload', parameters('spokeToken')), 80)]",
    "privateEndpointsSubnetName": "[take(format('snet-{0}-private-endpoints', parameters('spokeToken')), 80)]",
    "workloadSubnetPrefixes": [
      "[parameters('subnetPrefixes').workload]",
      "[parameters('subnetPrefixes').privateEndpoints]"
    ]
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('nsg-{0}', variables('workloadSubnetName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowIntraSpokeInbound",
            "properties": {
              "description": "Allows traffic that stays inside the workload spoke boundary.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefixes": "[parameters('addressPrefixes')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowOperatorP2SInbound",
            "properties": {
              "description": "Allows approved break-glass operators to reach the workload subnet through the hub gateway.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('vpnClientAddressPool')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "access": "Allow",
              "priority": 110,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyHubPlatformInbound",
            "properties": {
              "description": "Prevents hub platform and runner subnets from initiating traffic into the workload subnet.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefixes": "[parameters('hubAddressPrefixes')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "access": "Deny",
              "priority": 3000,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenySpokeSupernetInbound",
            "properties": {
              "description": "Blocks lateral traffic from other spokes that share the reserved spoke supernet.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('futureSpokeSupernet')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "access": "Deny",
              "priority": 3100,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyInternetInbound",
            "properties": {
              "description": "Keeps the workload subnet private by default.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4000,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowIntraSpokeOutbound",
            "properties": {
              "description": "Allows traffic that stays inside the workload spoke boundary.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefixes": "[variables('workloadSubnetPrefixes')]",
              "access": "Allow",
              "priority": 100,
              "direction": "Outbound"
            }
          },
          {
            "name": "AllowHubSharedServicesOutbound",
            "properties": {
              "description": "Allows workloads to reach approved shared services hosted in the hub.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefix": "[parameters('hubSharedServicesPrefix')]",
              "access": "Allow",
              "priority": 200,
              "direction": "Outbound"
            }
          },
          {
            "name": "AllowHubPrivateEndpointsOutbound",
            "properties": {
              "description": "Allows workloads to consume hub-hosted private endpoints such as the shared registry path.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefix": "[parameters('hubPrivateEndpointsPrefix')]",
              "access": "Allow",
              "priority": 210,
              "direction": "Outbound"
            }
          },
          {
            "name": "DenyHubPlatformOutbound",
            "properties": {
              "description": "Prevents workloads from reaching non-approved hub subnets over the peering.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefixes": "[parameters('hubAddressPrefixes')]",
              "access": "Deny",
              "priority": 3000,
              "direction": "Outbound"
            }
          },
          {
            "name": "DenySpokeSupernetOutbound",
            "properties": {
              "description": "Blocks lateral traffic from the workload subnet to other spokes.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefix": "[parameters('futureSpokeSupernet')]",
              "access": "Deny",
              "priority": 3100,
              "direction": "Outbound"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('nsg-{0}', variables('privateEndpointsSubnetName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowWorkloadInbound",
            "properties": {
              "description": "Allows workload resources inside the same spoke to consume local private endpoints.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').workload]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowOperatorP2SInbound",
            "properties": {
              "description": "Allows approved break-glass operators to reach spoke private endpoints for diagnostics.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('vpnClientAddressPool')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "access": "Allow",
              "priority": 110,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyHubPlatformInbound",
            "properties": {
              "description": "Prevents hub platform and runner subnets from initiating traffic into the private-endpoints subnet.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefixes": "[parameters('hubAddressPrefixes')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "access": "Deny",
              "priority": 3000,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenySpokeSupernetInbound",
            "properties": {
              "description": "Blocks lateral traffic from other spokes that share the reserved spoke supernet.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('futureSpokeSupernet')]",
              "destinationAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "access": "Deny",
              "priority": 3100,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyInternetInbound",
            "properties": {
              "description": "Keeps the spoke private-endpoints subnet private by default.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4000,
              "direction": "Inbound"
            }
          },
          {
            "name": "AllowIntraSpokeOutbound",
            "properties": {
              "description": "Allows the private-endpoints subnet to return traffic only inside the local spoke boundary.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "destinationAddressPrefixes": "[variables('workloadSubnetPrefixes')]",
              "access": "Allow",
              "priority": 100,
              "direction": "Outbound"
            }
          },
          {
            "name": "DenyHubPlatformOutbound",
            "properties": {
              "description": "Prevents private endpoints from becoming a pivot into the wider hub platform network.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "destinationAddressPrefixes": "[parameters('hubAddressPrefixes')]",
              "access": "Deny",
              "priority": 3000,
              "direction": "Outbound"
            }
          },
          {
            "name": "DenySpokeSupernetOutbound",
            "properties": {
              "description": "Blocks lateral traffic from the private-endpoints subnet to other spokes.",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "destinationAddressPrefix": "[parameters('futureSpokeSupernet')]",
              "access": "Deny",
              "priority": 3100,
              "direction": "Outbound"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2024-05-01",
      "name": "[format('rt-{0}', variables('workloadSubnetName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "disableBgpRoutePropagation": false,
        "routes": []
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2024-05-01",
      "name": "[format('rt-{0}', variables('privateEndpointsSubnetName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "disableBgpRoutePropagation": false,
        "routes": []
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": "[parameters('addressPrefixes')]"
        },
        "subnets": [
          {
            "name": "[variables('workloadSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('subnetPrefixes').workload]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('workloadSubnetName')))]"
              },
              "routeTable": {
                "id": "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('workloadSubnetName')))]"
              }
            }
          },
          {
            "name": "[variables('privateEndpointsSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('subnetPrefixes').privateEndpoints]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('privateEndpointsSubnetName')))]"
              },
              "routeTable": {
                "id": "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('privateEndpointsSubnetName')))]"
              },
              "privateEndpointNetworkPolicies": "Disabled",
              "privateLinkServiceNetworkPolicies": "Enabled"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('privateEndpointsSubnetName')))]",
        "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('privateEndpointsSubnetName')))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('workloadSubnetName')))]",
        "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('workloadSubnetName')))]"
      ]
    }
  ],
  "outputs": {
    "spoke": {
      "type": "object",
      "value": {
        "name": "[parameters('spokeName')]",
        "resourceGroupName": "[resourceGroup().name]",
        "vnetName": "[parameters('vnetName')]",
        "vnetId": "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "subnetNames": {
          "workload": "[variables('workloadSubnetName')]",
          "privateEndpoints": "[variables('privateEndpointsSubnetName')]"
        },
        "subnetIds": {
          "workload": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), variables('workloadSubnetName'))]",
          "privateEndpoints": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), variables('privateEndpointsSubnetName'))]"
        },
        "routeTables": {
          "workload": "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('workloadSubnetName')))]",
          "privateEndpoints": "[resourceId('Microsoft.Network/routeTables', format('rt-{0}', variables('privateEndpointsSubnetName')))]"
        },
        "networkSecurityGroups": {
          "workload": "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('workloadSubnetName')))]",
          "privateEndpoints": "[resourceId('Microsoft.Network/networkSecurityGroups', format('nsg-{0}', variables('privateEndpointsSubnetName')))]"
        },
        "addressPlan": {
          "vnetPrefixes": "[parameters('addressPrefixes')]",
          "subnetPrefixes": "[parameters('subnetPrefixes')]",
          "constraints": [
            "[format('Allocate workload spoke prefixes from the reserved future spoke supernet {0}.', parameters('futureSpokeSupernet'))]",
            "[format('Do not overlap workload spokes with hub prefixes {0} or with other spokes.', join(parameters('hubAddressPrefixes'), ', '))]",
            "[format('Reserve the declared future prefix {0} for later in-spoke growth so workloads do not need renumbering.', parameters('subnetPrefixes').reservedFuture)]"
          ]
        },
        "trafficModel": {
          "allowedInbound": [
            "[format('Break-glass operators from {0} may reach workload and private-endpoint subnets.', parameters('vpnClientAddressPool'))]",
            "Traffic that stays inside the local spoke address space remains allowed."
          ],
          "allowedOutbound": [
            "[format('Workloads can reach the hub shared-services subnet {0}.', parameters('hubSharedServicesPrefix'))]",
            "[format('Workloads can reach the hub private-endpoints subnet {0}.', parameters('hubPrivateEndpointsPrefix'))]",
            "Private-endpoint resources return traffic only inside the same spoke."
          ],
          "blockedByDefault": [
            "Hub platform subnets other than approved shared-services and private-endpoints prefixes are denied.",
            "[format('Spoke-to-spoke traffic across the reserved supernet {0} is denied at the subnet boundary.', parameters('futureSpokeSupernet'))]",
            "Internet-originated inbound traffic remains denied by default."
          ]
        }
      }
    }
  }
}